generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  displayName   String
  email         String    @unique
  emailVerified DateTime? @db.Timestamptz(3)
  image         String?
  passwordHash  String?
  roleId        String?   @db.Uuid

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  role     Role?     @relation("RoleUsers", fields: [roleId], references: [id], onDelete: SetNull)
  accounts Account[]
  sessions Session[]

  createdBy User? @relation("UserCreatedUsers", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedUsers", fields: [updatedById], references: [id], onDelete: SetNull)

  createdUsers          User[]                @relation("UserCreatedUsers")
  updatedUsers          User[]                @relation("UserUpdatedUsers")
  createdRoles          Role[]                @relation("UserCreatedRoles")
  updatedRoles          Role[]                @relation("UserUpdatedRoles")
  createdCustomers      Customer[]            @relation("UserCreatedCustomers")
  updatedCustomers      Customer[]            @relation("UserUpdatedCustomers")
  createdSalesReps      SalesRep[]            @relation("UserCreatedSalesReps")
  updatedSalesReps      SalesRep[]            @relation("UserUpdatedSalesReps")
  createdOrders         Order[]               @relation("UserCreatedOrders")
  updatedOrders         Order[]               @relation("UserUpdatedOrders")
  createdDeliveries     Delivery[]            @relation("UserCreatedDeliveries")
  updatedDeliveries     Delivery[]            @relation("UserUpdatedDeliveries")
  createdPallets        Pallet[]              @relation("UserCreatedPallets")
  updatedPallets        Pallet[]              @relation("UserUpdatedPallets")
  createdSchedules      OperationalSchedule[] @relation("UserCreatedOperationalSchedules")
  updatedSchedules      OperationalSchedule[] @relation("UserUpdatedOperationalSchedules")
  uploadedImportBatches ImportBatch[]         @relation("ImportBatchUploadedBy")
  createdImportBatches  ImportBatch[]         @relation("UserCreatedImportBatches")
  updatedImportBatches  ImportBatch[]         @relation("UserUpdatedImportBatches")
  createdImportRows     ImportRow[]           @relation("UserCreatedImportRows")
  updatedImportRows     ImportRow[]           @relation("UserUpdatedImportRows")
  createdShipments      Shipment[]            @relation("UserCreatedShipments")
  updatedShipments      Shipment[]            @relation("UserUpdatedShipments")
  createdCarriers       Carrier[]             @relation("UserCreatedCarriers")
  updatedCarriers       Carrier[]             @relation("UserUpdatedCarriers")
  createdRepIssues      RepIssue[]            @relation("UserCreatedRepIssues")
  updatedRepIssues      RepIssue[]            @relation("UserUpdatedRepIssues")
  createdActivities     Activity[]            @relation("UserCreatedActivities")
  updatedActivities     Activity[]            @relation("UserUpdatedActivities")
  createdNotifications  Notification[]        @relation("UserCreatedNotifications")
  updatedNotifications  Notification[]        @relation("UserUpdatedNotifications")
  createdAttachments    Attachment[]          @relation("UserCreatedAttachments")
  updatedAttachments    Attachment[]          @relation("UserUpdatedAttachments")
  createdAppSettings    AppSetting[]          @relation("UserCreatedAppSettings")
  updatedAppSettings    AppSetting[]          @relation("UserUpdatedAppSettings")
  activities            Activity[]            @relation("ActivityActor")
  notifications         Notification[]        @relation("NotificationUser")

  @@index([roleId])
  @@index([displayName])
  @@index([deletedAt])
  @@map("user")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(3)

  @@unique([identifier, token])
  @@map("verification_token")
}

model Role {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  users     User[] @relation("RoleUsers")
  createdBy User?  @relation("UserCreatedRoles", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("UserUpdatedRoles", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("role")
}

model Customer {
  id         String  @id @default(uuid()) @db.Uuid
  name       String
  salesRepId String? @db.Uuid

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  salesRep  SalesRep?  @relation("SalesRepCustomers", fields: [salesRepId], references: [id], onDelete: SetNull)
  orders    Order[]
  repIssues RepIssue[]
  createdBy User?      @relation("UserCreatedCustomers", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("UserUpdatedCustomers", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([salesRepId])
  @@map("customer")
}

model SalesRep {
  id   String @id @default(uuid()) @db.Uuid
  name String

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  customers Customer[] @relation("SalesRepCustomers")
  repIssues RepIssue[]
  createdBy User?      @relation("UserCreatedSalesReps", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("UserUpdatedSalesReps", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([name])
  @@map("sales_rep")
}

model Order {
  id             String    @id @default(uuid()) @db.Uuid
  orderNumber    String    @unique
  pickingNumber  String?
  goodsIssueDate DateTime? @db.Date
  shipToNumber   String?
  routeCode      String?
  grossWeightKg  Decimal?  @db.Decimal(12, 3)
  customerId     String    @db.Uuid

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  deliveries Delivery[]
  createdBy  User?      @relation("UserCreatedOrders", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?      @relation("UserUpdatedOrders", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([pickingNumber])
  @@index([goodsIssueDate])
  @@index([shipToNumber])
  @@index([routeCode])
  @@map("order")
}

model Delivery {
  id             String  @id @default(uuid()) @db.Uuid
  deliveryNumber String  @unique
  orderId        String  @db.Uuid
  shipmentId     String? @db.Uuid

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  order                Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  shipment             Shipment?             @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  pallets              Pallet[]
  operationalSchedules OperationalSchedule[]
  createdBy            User?                 @relation("UserCreatedDeliveries", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy            User?                 @relation("UserUpdatedDeliveries", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([shipmentId])
  @@map("delivery")
}

model OperationalSchedule {
  id                    String   @id @default(uuid()) @db.Uuid
  deliveryId            String   @db.Uuid
  source                String
  scheduledDispatchDate DateTime @db.Date
  sourceReference       String?

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  delivery  Delivery @relation(fields: [deliveryId], references: [id], onDelete: Restrict)
  createdBy User?    @relation("UserCreatedOperationalSchedules", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("UserUpdatedOperationalSchedules", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([deliveryId, source])
  @@index([scheduledDispatchDate])
  @@index([source])
  @@map("operational_schedule")
}

model ImportBatch {
  id                String    @id @default(uuid()) @db.Uuid
  importType        String
  status            String
  originalFileName  String
  selectedSheetName String?
  selectedHeaderRow Int?
  mapping           Json?
  previewVersion    Int       @default(0)
  uploadedByUserId  String    @db.Uuid
  committedAt       DateTime? @db.Timestamptz(3)
  totalRows         Int       @default(0)
  validRows         Int       @default(0)
  importedRows      Int       @default(0)
  skippedRows       Int       @default(0)
  failedRows        Int       @default(0)

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  uploadedBy User        @relation("ImportBatchUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  createdBy  User?       @relation("UserCreatedImportBatches", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?       @relation("UserUpdatedImportBatches", fields: [updatedById], references: [id], onDelete: SetNull)
  rows       ImportRow[]

  @@index([uploadedByUserId])
  @@index([status])
  @@index([createdAt])
  @@map("import_batch")
}

model ImportRow {
  id              String  @id @default(uuid()) @db.Uuid
  batchId         String  @db.Uuid
  sourceRowNumber Int
  sheetName       String
  identifier      String?
  classification  String
  message         String?
  mappedValues    Json?
  currentValues   Json?
  proposedValues  Json?

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  batch     ImportBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)
  createdBy User?       @relation("UserCreatedImportRows", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?       @relation("UserUpdatedImportRows", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([batchId, sheetName, sourceRowNumber])
  @@index([batchId, sheetName])
  @@index([batchId, classification])
  @@map("import_row")
}

model Pallet {
  id             String  @id @default(uuid()) @db.Uuid
  deliveryId     String  @db.Uuid
  sequenceNumber Int
  actualWeight   Decimal @db.Decimal(12, 3)

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  delivery  Delivery @relation(fields: [deliveryId], references: [id], onDelete: Restrict)
  createdBy User?    @relation("UserCreatedPallets", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("UserUpdatedPallets", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([deliveryId, sequenceNumber])
  @@index([deliveryId, deletedAt])
  @@map("pallet")
}

model Shipment {
  id             String    @id @default(uuid()) @db.Uuid
  shipmentNumber String    @unique
  dispatchDate   DateTime? @db.Date
  deliveryDate   DateTime? @db.Date
  actualPallets  Int?
  actualWeight   Decimal?  @db.Decimal(12, 3)
  notes          String?
  carrierId      String    @db.Uuid

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  carrier    Carrier    @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  deliveries Delivery[]
  createdBy  User?      @relation("UserCreatedShipments", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?      @relation("UserUpdatedShipments", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([carrierId])
  @@index([dispatchDate])
  @@map("shipment")
}

model Carrier {
  id   String @id @default(uuid()) @db.Uuid
  name String

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  shipments Shipment[]
  createdBy User?      @relation("UserCreatedCarriers", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("UserUpdatedCarriers", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("carrier")
}

model RepIssue {
  id          String @id @default(uuid()) @db.Uuid
  description String
  salesRepId  String @db.Uuid
  customerId  String @db.Uuid

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  salesRep  SalesRep @relation(fields: [salesRepId], references: [id], onDelete: Restrict)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User?    @relation("UserCreatedRepIssues", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("UserUpdatedRepIssues", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([salesRepId])
  @@index([customerId])
  @@map("rep_issue")
}

model Activity {
  id          String   @id @default(uuid()) @db.Uuid
  entityType  String
  entityId    String   @db.Uuid
  action      String
  description String
  metadata    Json?
  actorId     String   @db.Uuid
  occurredAt  DateTime @default(now()) @db.Timestamptz(3)

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  actor     User  @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Restrict)
  createdBy User? @relation("UserCreatedActivities", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedActivities", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([occurredAt])
  @@map("activity")
}

model Notification {
  id      String @id @default(uuid()) @db.Uuid
  title   String
  message String
  userId  String @db.Uuid

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  user      User  @relation("NotificationUser", fields: [userId], references: [id], onDelete: Restrict)
  createdBy User? @relation("UserCreatedNotifications", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedNotifications", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("notification")
}

model Attachment {
  id         String  @id @default(uuid()) @db.Uuid
  entityType String
  entityId   String  @db.Uuid
  fileName   String
  storageKey String
  mimeType   String?
  sizeBytes  Int?

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  createdBy User? @relation("UserCreatedAttachments", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedAttachments", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("attachment")
}

model AppSetting {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value Json

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  createdById String?   @db.Uuid
  updatedById String?   @db.Uuid
  deletedAt   DateTime? @db.Timestamptz(3)

  createdBy User? @relation("UserCreatedAppSettings", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedAppSettings", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("app_setting")
}
